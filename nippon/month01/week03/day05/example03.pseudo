BEGIN 
    INPUT weather
    IF weather = "Бороотой" THEN 
      OUTPUT "Цув аваарай"
    ELSE 
      OUTPUT "Цув хэрэггүй"
    ENDIF
END       

BEGIN 
   INPUT Hour 
   if hour >= 9 AND hour <= 21 THEN 
     OUTPUT "Дэлгүүр нээлттэй"
  ELSE 
     OUTPUT "Дэлгүүр хаалттай"
  ENDIF
END         
    
   